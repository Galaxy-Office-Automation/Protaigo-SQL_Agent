LENGTH(filler) as filler_len
FROM pgbench_accounts
WHERE aid <= 2500000 
),
ROLLING_METRICS AS MATERIALIZED (
SELECT
aid,
bid,
abalance,
synthetic_date,
SUM(abalance) OVER (
PARTITION BY bid
-- (Redundant ORDER BY removed)
ROWS BETWEEN 2000 PRECEDING AND 2000 FOLLOWING
) as rolling_sum_4000,
AVG(abalance) OVER (
PARTITION BY bid
-- (Redundant ORDER BY removed)
ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
) as cumulative_avg,
STDDEV(abalance) OVER (
PARTITION BY bid
-- (Redundant ORDER BY removed)
ROWS BETWEEN 1000 PRECEDING AND CURRENT ROW
) as rolling_volatility,
MAX(abalance) OVER (
PARTITION BY bid
-- (Redundant ORDER BY removed)
ROWS BETWEEN 5000 PRECEDING AND 5000 FOLLOWING
) as rolling_max
FROM base_data
),
VOLATILITY_CLUSTERS AS MATERIALIZED (
